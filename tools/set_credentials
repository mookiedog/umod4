#!/usr/bin/env python3
"""
Write WiFi credentials (and optionally device name) to a umod4 device
that is currently in AP mode, via the ap_proxy Pico W.

Usage:
    build/.venv/bin/python3 tools/set_credentials [options]

Examples:
    # Set WiFi credentials only:
    build/.venv/bin/python3 tools/set_credentials --ssid MyNetwork --password secret

    # Set credentials and give the device a name in one shot:
    build/.venv/bin/python3 tools/set_credentials --name garage --ssid MyNetwork --password secret

    # Specify the ap_proxy serial port explicitly:
    build/.venv/bin/python3 tools/set_credentials --port /dev/ttyACM1 --ssid MyNetwork --password secret

The device will reboot after saving. At least one of --ssid or --name must be provided.
"""

import argparse
import glob
import json
import os
import sys
import time
import serial

BAUD = 115200

# VID:PID loaded from tools/ap_proxy/usb_ids.txt (single source of truth).
def _load_usb_ids():
    path = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                        "ap_proxy", "usb_ids.txt")
    ids = {}
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith('#'):
                k, _, v = line.partition('=')
                ids[k.strip()] = v.strip()
    return ids

_usb_ids = _load_usb_ids()
AP_PROXY_VID = int(_usb_ids["AP_PROXY_VID"], 16)
AP_PROXY_PID = int(_usb_ids["AP_PROXY_PID"], 16)
AP_PROXY_HW_ID = f"{_usb_ids['AP_PROXY_VID'].lower()}:{_usb_ids['AP_PROXY_PID'].lower()}"


# ---------------------------------------------------------------------------
# Serial helpers
# ---------------------------------------------------------------------------

def _send(ser, line):
    ser.reset_input_buffer()
    ser.write((line.rstrip('\n') + '\n').encode())
    ser.flush()


def _recv(ser, timeout):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        raw = ser.readline()
        if raw:
            line = raw.decode(errors='replace').strip()
            if line.startswith('OK') or line.startswith('ERR'):
                return line
    raise TimeoutError(f"No response after {timeout}s")


def cmd(ser, line, timeout=20.0):
    _send(ser, line)
    return _recv(ser, timeout)


# ---------------------------------------------------------------------------
# Port discovery
# ---------------------------------------------------------------------------

def _try_ping(port):
    try:
        with serial.Serial(port, BAUD, timeout=1.0) as ser:
            time.sleep(0.3)
            ser.reset_input_buffer()
            ser.write(b"PING\n")
            ser.flush()
            deadline = time.monotonic() + 2.0
            while time.monotonic() < deadline:
                raw = ser.readline()
                if raw and raw.strip().startswith(b"OK"):
                    return True
    except (serial.SerialException, OSError):
        pass
    return False


def find_proxy_port():
    # Try pyserial's list_ports first (matches VID:PID cleanly)
    try:
        import serial.tools.list_ports
        for p in serial.tools.list_ports.comports():
            if p.vid == AP_PROXY_VID and p.pid == AP_PROXY_PID:
                return p.device
    except Exception:
        pass

    # Fallback: ping all ttyACM* devices
    candidates = sorted(glob.glob("/dev/ttyACM*"))
    for port in candidates:
        if _try_ping(port):
            return port
    return None


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Write WiFi credentials to a umod4 device in AP mode.")
    parser.add_argument("--port",     help="Serial port for ap_proxy (auto-detected if omitted)")
    parser.add_argument("--ssid",     help="Home WiFi network SSID")
    parser.add_argument("--password", help="Home WiFi network password")
    parser.add_argument("--name",     help="Device name to store in flash")
    args = parser.parse_args()

    if args.ssid is None:
        env_ssid = os.environ.get('UMOD4_WIFI_SSID')
        if env_ssid is None:
            parser.error("--ssid not specified and UMOD4_WIFI_SSID environment variable is not set.")
        args.ssid = env_ssid
        print(f"Using UMOD4_WIFI_SSID from environment.")

    if args.password is None:
        env_password = os.environ.get('UMOD4_WIFI_PASSWORD')
        if env_password is None:
            parser.error("--password not specified and UMOD4_WIFI_PASSWORD environment variable is not set.")
        args.password = env_password
        print(f"Using UMOD4_WIFI_PASSWORD from environment.")

    # --- Find ap_proxy port ---
    if args.port:
        port = args.port
        print(f"Using specified port: {port}")
    else:
        print("Looking for ap_proxy...")
        port = find_proxy_port()
        if not port:
            print("ERROR: ap_proxy not found.")
            print(f"  - Is the ap_proxy plugged in? (VID:PID {AP_PROXY_HW_ID})")
            print(f"  - On WSL: usbipd.exe attach --wsl --hardware-id {AP_PROXY_HW_ID}")
            sys.exit(1)
        print(f"Found ap_proxy on {port}")

    with serial.Serial(port, BAUD, timeout=2.0) as ser:
        time.sleep(0.5)
        ser.reset_input_buffer()

        # --- Ping ---
        print("Pinging ap_proxy...", end=" ", flush=True)
        resp = cmd(ser, "PING", timeout=3.0)
        if not resp.startswith("OK"):
            print(f"FAIL ({resp})")
            sys.exit(1)
        print("OK")

        # --- Scan ---
        print("Scanning for umod4 networks...", end=" ", flush=True)
        resp = cmd(ser, "SCAN", timeout=20.0)
        if resp.startswith("ERR"):
            print(f"FAIL ({resp})")
            sys.exit(1)
        ssids = [s for s in resp.split()[1:] if s.startswith("umod4_")]
        if not ssids:
            print("FAIL\nERROR: No umod4_XXXX network found. Is the umod4 device powered on and in AP mode (LED slow blink)?")
            sys.exit(1)
        ssid = ssids[0]
        print(f"found {ssid}")

        # Brief pause after scan: the CYW43 radio needs time to settle back to
        # a single channel after a multi-channel scan before a connect can succeed.
        time.sleep(1.0)

        # --- Connect ---
        # Default AP password is the SSID itself
        print(f"Connecting to {ssid}...", end=" ", flush=True)
        resp = cmd(ser, f"CONNECT {ssid} {ssid}", timeout=30.0)
        if resp.startswith("ERR"):
            print(f"FAIL ({resp})")
            sys.exit(1)
        parts = resp.split()
        ip = parts[2] if len(parts) >= 3 else "192.168.4.1"
        print(f"OK (IP {ip})")

        # --- Build config payload ---
        payload = {}
        if args.ssid:
            payload["wifi_ssid"] = args.ssid
        if args.password:
            payload["wifi_password"] = args.password
        if args.name:
            payload["device_name"] = args.name

        body_str = json.dumps(payload, separators=(',', ':'))
        print(f"Posting config")

        resp = cmd(ser, f"POST /api/config {body_str}", timeout=15.0)
        if resp.startswith("ERR"):
            print(f"FAIL ({resp})")
            sys.exit(1)

        parts = resp.split(None, 2)
        http_code = int(parts[1]) if len(parts) >= 2 and parts[1].isdigit() else 0
        if http_code != 200:
            print(f"FAIL (HTTP {http_code}: {resp})")
            sys.exit(1)

        print("Config saved. Device is rebooting.")


if __name__ == "__main__":
    main()
