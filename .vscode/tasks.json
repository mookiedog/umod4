{
    "version": "2.0.0",
    "tasks": [
        {
            // Attach the CMSIS-DAP debug probe to WSL via usbipd.
            // Called automatically by preLaunchTask in each debug configuration.
            // Requires setup_usb_wsl.ps1 to have been run once as Administrator.
            "label": "usbipd: attach debug probe",
            "type": "shell",
            "command": "usbipd.exe attach --hardware-id 2e8a:000c --wsl",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": true
            },
            "problemMatcher": []
        },
        {
            // Detach the CMSIS-DAP debug probe from WSL, returning it to Windows.
            // Called automatically by postDebugTask in each debug configuration.
            "label": "usbipd: detach debug probe",
            "type": "shell",
            "command": "usbipd.exe detach --hardware-id 2e8a:000c",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "close": true
            },
            "problemMatcher": []
        },
        {
            // Load WpUsbBoot RAM stub via OpenOCD to put WP into USB mass-storage bootloader mode.
            // Requires debug probe connected to WP SWD header.  No BOOTSEL button needed.
            // The SPARE1 LED will light for ~1 second, then WP reboots into USB boot mode.
            "label": "WP: Enter USB Boot Mode (WpUsbBoot)",
            "type": "shell",
            "command": "openocd -f interface/cmsis-dap.cfg -f target/rp2350.cfg -c 'adapter speed 5000' -c 'init' -c 'reset halt' -c 'rbp all' -c 'load_image ${workspaceRoot}/build/WpUsbBoot/WpUsbBoot' -c 'targets rp2350.cm0' -c 'set sp_val [lindex [read_memory 0x20000000 32 1] 0]' -c 'set pc_val [lindex [read_memory 0x20000004 32 1] 0]' -c 'reg sp $sp_val' -c 'reg pc $pc_val' -c 'resume' -c 'sleep 10000' -c 'exit'",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Flash WP firmware via SWD + picotool.
            // Uses wp_enter_bootsel to force WP into USB BOOTSEL mode via the debug probe,
            // then flashes with picotool.  Requires CMSIS-DAP debug probe connected to WP.
            //
            // This writes both the partition table (ABSOLUTE blocks) and the
            // application image into slot A.  Using OpenOCD's 'program WP.elf'
            // instead would overwrite the partition table at 0x10000000 and
            // break OTA — do NOT use that approach.
            "label": "WP: Flash and Run (force BOOTSEL via SWD)",
            "type": "shell",
            "command": "~/projects/umod4/tools/wp_enter_bootsel ${workspaceRoot}/build/WpUsbBoot/WpUsbBoot && ~/projects/umod4/tools/flash_WP ${workspaceRoot}/build/WP",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Flash WP firmware using picotool.
            // Assumes WP is already in USB BOOTSEL (mass-storage) mode —
            // either via wp_enter_bootsel or by holding BOOTSEL while pressing RESET.
            //
            // This writes both the partition table (ABSOLUTE blocks) and the
            // application image into slot A.  Using OpenOCD's 'program WP.elf'
            // instead would overwrite the partition table at 0x10000000 and
            // break OTA — do NOT use that approach.
            "label": "WP: Flash and Run (BOOTSEL mode)",
            "type": "shell",
            "command": "~/projects/umod4/tools/flash_WP ${workspaceRoot}/build/WP",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Erase only slot 0 (the image selector, 64KB at 0x10200000).
            // Sufficient to force EP into limp mode without touching slot data.
            // Use before launching EP when you want to test the empty-store boot path.
            "label": "EP: Erase Image Store Selector",
            "type": "shell",
            "command": "openocd -f interface/cmsis-dap.cfg -f target/rp2040.cfg -c 'adapter speed 5000; init; reset halt; flash erase_address pad 0x10200000 0x10000; reset run; exit'",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            // Erase the entire image store partition (128 slots × 64KB = 8MB).
            // Use for a full factory reset of the image store.
            // Warning: takes ~30 seconds for 8MB of flash erase.
            "label": "EP: Erase Full Image Store (8MB)",
            "type": "shell",
            "command": "openocd -f interface/cmsis-dap.cfg -f target/rp2040.cfg -c 'adapter speed 5000; init; reset halt; flash erase_address pad 0x10200000 0x800000; reset run; exit'",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
